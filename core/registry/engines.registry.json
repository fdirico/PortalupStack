{
  "version": "0.2.0",
  "engines": {
    "claude": {
      "status": "validated-package",
      "adapter": "core/adapters/claude/adapter.md",
      "runtime": {
        "authEnvVar": "ANTHROPIC_API_KEY",
        "defaultModel": "claude-sonnet-4-6",
        "maxContextTokens": 200000,
        "sdkPackage": "@anthropic-ai/sdk",
        "supportsStreaming": true,
        "supportsCaching": true
      },
      "supports": {
        "fileRead": true,
        "fileWrite": true,
        "commandExecution": true,
        "nativeSkills": true,
        "handoff": true
      }
    },
    "openai": {
      "status": "runtime-v1",
      "adapter": "core/adapters/openai/adapter.md",
      "runtime": {
        "authEnvVar": "OPENAI_API_KEY",
        "defaultModel": "gpt-4o",
        "maxContextTokens": 128000,
        "sdkPackage": "openai",
        "supportsStreaming": true,
        "supportsCaching": false
      },
      "supports": {
        "fileRead": false,
        "fileWrite": false,
        "commandExecution": false,
        "nativeSkills": false,
        "handoff": true
      }
    },
    "codex": {
      "status": "baseline",
      "adapter": "core/adapters/codex/adapter.md",
      "supports": {
        "fileRead": true,
        "fileWrite": true,
        "commandExecution": true,
        "nativeSkills": true,
        "handoff": true
      }
    },
    "cursor": {
      "status": "planned",
      "adapter": "core/adapters/cursor/adapter.md",
      "supports": {
        "fileRead": true,
        "fileWrite": true,
        "commandExecution": "host-dependent",
        "nativeSkills": "to-be-defined",
        "handoff": true
      }
    }
  }
}
