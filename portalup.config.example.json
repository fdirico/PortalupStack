{
  "version": "0.5.0",
  "activeEngine": "claude",
  "mode": "autonomous",
  "defaultSkill": "portalup-orchestrator",
  "contextPolicy": "compact-and-handoff",
  "sessionDir": "outputs/sessions",
  "projectsDir": "",
  "statsFile": "outputs/stats.md",
  "handoffDir": "outputs/handoffs",
  "autoApprove": {
    "writeFile": true,
    "runCommand": false
  },
  "handoff": {
    "enabled": true,
    "template": "templates/agent-handoff.md",
    "continuityTemplate": "templates/continuity-summary.md"
  },
  "engines": {
    "claude": {
      "enabled": true,
      "adapter": "core/adapters/claude/adapter.md"
    },
    "openai": {
      "enabled": true,
      "adapter": "core/adapters/openai/adapter.md"
    },
    "codex": {
      "enabled": false,
      "adapter": "core/adapters/codex/adapter.md"
    },
    "cursor": {
      "enabled": false,
      "adapter": "core/adapters/cursor/adapter.md"
    }
  }
}
