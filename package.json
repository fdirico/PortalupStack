{
  "name": "portalup-stack",
  "version": "0.6.0",
  "description": "PortalUP Stack — AI development runtime with cross-LLM orchestration, session persistence, and analytics",
  "main": "dist/orchestrator.js",
  "scripts": {
    "build": "npx tsc",
    "build:check": "npx tsc --noEmit",
    "build": "npx tsc",
    "build:plugin": "cd vscode-pstack && npx tsc -p tsconfig.json",
    "build:check": "npx tsc --noEmit",
    "test": "node --test tests/runtime/**/*.test.js",
    "test:ts": "node --require ts-node/register --test tests/runtime/**/*.test.ts",
    "test:plugin": "node --require ts-node/register/transpile-only --test vscode-pstack/tests/file-tools.test.ts vscode-pstack/tests/shell-tools.test.ts vscode-pstack/tests/runtime-bridge.test.ts",
    "test:all": "npm run test:ts && npm run test:plugin",
    "validate": "node scripts/validate-all.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "openai": "^4.77.0",
    "portalup-stack": "file:"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
